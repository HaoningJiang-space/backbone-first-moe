+void ArcherPrefetchHandle::PinResidentNodes(const std::vector<std::uint32_t>& node_ids)
+{
+    // Load each resident node to GPU and mark as non-evictable.
+    // 将每个常驻节点加载到 GPU 并标记为不可驱逐。
+    std::size_t pinned = 0;
+    for (auto nid : node_ids) {
+        auto node = kTopologyHandle->GetNodeFromTensorID(nid);
+        if (!node) {
+            ARCHER_LOG_WARN("PinResidentNodes: tensor_id {} not found, skipping", nid);
+            continue;
+        }
+        if (node->is_resident) { continue; }  // already pinned
+
+        node->is_resident = true;
+
+        // Load to GPU if not already there
+        // 如果尚不在 GPU 上，加载到 GPU
+        if (!node->device.is_cuda()) {
+            std::lock_guard<std::mutex> lock(node->mutex);
+            node->SetDevice(node->default_device);
+        }
+
+        // Set very high visit count so LFU never picks it even if
+        // is_resident check is somehow bypassed.
+        // 设置极高访问计数，即使 is_resident 检查被绕过，LFU 也不会选中它。
+        node->incache_visit_count = UINT64_MAX / 2;
+        node->prob = 1.0;
+        pinned++;
+    }
+    ARCHER_LOG_INFO("PinResidentNodes: pinned {} nodes on GPU", pinned);
+}
